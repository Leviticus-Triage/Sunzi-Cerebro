# Sunzi Cerebro Backend Configuration
# Copy this file to .env and update with your values

# Server Configuration
NODE_ENV=development
PORT=8000
HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5

# Database Configuration
DB_DIALECT=sqlite
DB_PATH=./data/cerebrum.db
# For PostgreSQL/MySQL in production:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cerebrum
# DB_USER=cerebrum_user
# DB_PASSWORD=your_db_password
# DB_POOL_MAX=10
# DB_POOL_MIN=0
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=10000

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30000
OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_PULL_TIMEOUT=300000
OLLAMA_RETRIES=3

# Warp Terminal Configuration
WARP_SOCKET_PATH=/tmp/warp-terminal.sock
WARP_SESSION_TIMEOUT=3600000
WARP_EXPORT_PATH=./exports
WARP_MAX_SESSIONS=10
WARP_COMMAND_TIMEOUT=30000

# MCP Server Configuration
MCP_SERVERS_CONFIG=/home/danii/.config/warp-terminal/mcp_servers.json
MCP_DEFAULT_TIMEOUT=30000
MCP_MAX_RETRIES=3
MCP_HEALTH_CHECK_INTERVAL=60000

# File System Configuration
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.txt,.json,.js,.ts,.py,.md,.yml,.yaml,.log
EXPORT_PATH=./exports
BACKUP_PATH=./backups
WATCH_PATHS=/home/danii/.config/warp-terminal
MAX_WATCHERS=100

# WebSocket Configuration
WS_PING_INTERVAL=30000
WS_PONG_TIMEOUT=5000
WS_MAX_CONNECTIONS=100
WS_HEARTBEAT_INTERVAL=25000

# Security Configuration
SESSION_SECRET=your-session-secret-change-in-production
BCRYPT_SALT_ROUNDS=12

# Documentation Export Configuration (User Rules Integration)
DOC_EXPORT_INTERVAL=300000
WARP_EXPORT_PATH=./exports/warp-Terminal-export
AGENT_EXPORT_PATH=./exports/warp-Agent-export

# System Monitoring
MONITORING_INTERVAL=30000
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_DISK_THRESHOLD=90
METRICS_RETENTION_DAYS=7
LOGS_RETENTION_DAYS=30