{
  "name": "sunzi-cerebro-backend",
  "version": "1.0.0",
  "description": "Backend API server for Sunzi Cerebro - Advanced LLM orchestration and MCP server management",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "node scripts/test-runner.js",
    "test:suite": "jest --testPathPattern",
    "test:auth": "jest --testPathPattern=auth.test.js",
    "test:database": "jest --testPathPattern=database.test.js",
    "test:mcp": "jest --testPathPattern=mcp.test.js",
    "test:performance": "jest --testPathPattern=performance.test.js",
    "test:security": "jest --testPathPattern=security.test.js",
    "lint": "eslint . --ext .js,.json",
    "lint:fix": "eslint . --ext .js,.json --fix",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npm run db:migrate && npm run db:seed",
    "logs:clear": "rm -rf logs/* && echo 'Logs cleared'",
    "setup": "mkdir -p logs data exports backups && cp .env.example .env || true",
    "build": "echo 'Backend build completed'",
    "health": "curl -f http://localhost:8000/api/system/health || exit 1",
    "pretest": "mkdir -p test-reports coverage",
    "posttest": "echo 'Test suite completed. Check test-reports/ for detailed results.'"
  },
  "keywords": [
    "nodejs",
    "express",
    "api",
    "llm",
    "ollama",
    "mcp",
    "warp-terminal",
    "websocket",
    "security",
    "ai"
  ],
  "author": "Sunzi Cerebro Team",
  "license": "MIT",
  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "chokidar": "^3.5.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "redis": "^5.8.2",
    "sequelize": "^6.35.1",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.4",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "systeminformation": "^5.21.20",
    "unzipper": "^0.10.14",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@types/node": "^20.10.4",
    "babel-jest": "^30.2.0",
    "eslint": "^8.55.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-n": "^16.4.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.3.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/sunzi-cerebro-react-framework.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/sunzi-cerebro-react-framework/issues"
  },
  "homepage": "https://github.com/your-username/sunzi-cerebro-react-framework#readme"
}
