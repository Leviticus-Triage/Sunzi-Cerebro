# Beispiel-Umgebungsvariablen für lokale Entwicklung
# Kopiere diese Datei nach .env und passe die Werte an

# Frontend
VITE_API_BASE_URL=http://localhost:4000

# Optional: Feature-Flags
VITE_ENABLE_ANALYTICS=false

# CI/Deployment (werden in GitHub Actions als Secrets konfiguriert)
# AZURE_WEBAPP_PUBLISH_PROFILE=... (in GitHub Secrets)
# SLACK_WEBHOOK_URL=... (in GitHub Secrets)
