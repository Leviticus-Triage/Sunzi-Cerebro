# Sunzi Cerebro Enterprise - Production Environment Configuration
# Phase 5: Production Enhancement

# ==============================================================================
# 🌐 APPLICATION CONFIGURATION
# ==============================================================================

NODE_ENV=production
PORT=8890

# Application details
APP_NAME="Sunzi Cerebro Enterprise"
APP_VERSION="3.2.0"
APP_DESCRIPTION="Enterprise Security Intelligence Platform with 272+ Security Tools"

# ==============================================================================
# 🗄️  DATABASE CONFIGURATION
# ==============================================================================

# PostgreSQL Database (Production)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sunzi_cerebro
DB_USER=sunzi_cerebro
DB_PASSWORD=cerebro_production_2025
DB_SSL=false
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# Database migration settings
DB_MIGRATE_ON_START=true
DB_SEED_ON_START=false

# ==============================================================================
# 🚀 REDIS CONFIGURATION
# ==============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=10000
REDIS_COMMAND_TIMEOUT=5000

# Redis key prefixes
REDIS_PREFIX=sunzi:cerebro
REDIS_SESSION_PREFIX=session
REDIS_CACHE_PREFIX=cache

# ==============================================================================
# 🔐 SECURITY CONFIGURATION
# ==============================================================================

# JWT Configuration
JWT_SECRET=sunzi-cerebro-enterprise-jwt-secret-2025
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# Session Management
SESSION_SECRET=sunzi-cerebro-session-secret-2025
SESSION_TIMEOUT=28800000
SESSION_CLEANUP_INTERVAL=3600000

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
PASSWORD_MAX_AGE_DAYS=90

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_AUTH_MAX=5

# Security Headers
ENABLE_HELMET=true
ENABLE_CORS=true
CORS_ORIGIN=*
TRUST_PROXY=true

# ==============================================================================
# 🔧 MCP SERVERS CONFIGURATION
# ==============================================================================

# HexStrike AI Server
HEXSTRIKE_HOST=hexstrike-ai
HEXSTRIKE_PORT=8888
HEXSTRIKE_ENABLED=true
HEXSTRIKE_TIMEOUT=300000
HEXSTRIKE_RETRY_ATTEMPTS=3

# MCP-God-Mode Server
MCP_GODMODE_ENABLED=true
MCP_GODMODE_TIMEOUT=300000
MCP_GODMODE_MAX_CONCURRENT=5

# AttackMCP Server (STDIO - No port needed)
ATTACKMCP_ENABLED=true
ATTACKMCP_TYPE=stdio

# Notion MCP Server
NOTION_ENABLED=true
NOTION_API_KEY=ntn_T142672354291rL8erwWrk4rxchg1FEsMPqn4KGkWpN8vV

# ==============================================================================
# 📊 MONITORING & OBSERVABILITY
# ==============================================================================

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_ROTATION=daily

# Prometheus Metrics
METRICS_ENABLED=true
METRICS_PORT=9100
METRICS_PATH=/metrics
METRICS_PREFIX=sunzi_cerebro

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=10000
HEALTH_CHECK_RETRIES=3

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
SLOW_QUERY_THRESHOLD=1000
MEMORY_USAGE_THRESHOLD=80

# ==============================================================================
# 🌐 EXTERNAL INTEGRATIONS
# ==============================================================================

# Webhook Configuration
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Sunzi Cerebro <noreply@sunzi-cerebro.enterprise>"
SMTP_TLS=true

# Slack Integration
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_ENABLED=false

# ==============================================================================
# ☁️  CLOUD & DEPLOYMENT
# ==============================================================================

# Docker Configuration
DOCKER_REGISTRY=
DOCKER_NAMESPACE=sunzi-cerebro

# Kubernetes Configuration
K8S_NAMESPACE=sunzi-cerebro
K8S_SERVICE_ACCOUNT=sunzi-cerebro

# Load Balancer Configuration
LOAD_BALANCER_ENABLED=false
STICKY_SESSIONS=true

# ==============================================================================
# 🗂️  FILE STORAGE & UPLOADS
# ==============================================================================

# File Upload Configuration
UPLOAD_MAX_SIZE=100mb
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,txt,json,xml,csv
UPLOAD_PATH=/app/uploads

# Export Configuration
EXPORT_PATH=/app/exports
EXPORT_RETENTION_DAYS=30
EXPORT_MAX_SIZE=500mb

# Backup Configuration
BACKUP_PATH=/app/backups
BACKUP_RETENTION_DAYS=90
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"

# ==============================================================================
# 🚀 PERFORMANCE OPTIMIZATION
# ==============================================================================

# Application Performance
PM2_INSTANCES=2
NODE_OPTIONS="--max-old-space-size=2048"
UV_THREADPOOL_SIZE=16

# Database Connection Pooling
DB_CONNECTION_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_POOL_MAX_LIFETIME=1800000

# Caching Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100mb
ENABLE_QUERY_CACHE=true
ENABLE_RESPONSE_CACHE=true

# Compression
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6
COMPRESSION_THRESHOLD=1024

# ==============================================================================
# 🔍 DEBUGGING & DEVELOPMENT
# ==============================================================================

# Debug Configuration
DEBUG_ENABLED=false
DEBUG_NAMESPACE=sunzi:*
VERBOSE_LOGGING=false

# API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=/api/docs
API_DOCS_USERNAME=admin
API_DOCS_PASSWORD=sunzi-docs-2025

# ==============================================================================
# 🏢 MULTI-TENANCY CONFIGURATION
# ==============================================================================

# Tenant Configuration
DEFAULT_TENANT=sunzi-cerebro-enterprise
MAX_TENANTS=100
TENANT_ISOLATION=strict

# Subscription Limits
FREE_TIER_USERS=5
FREE_TIER_EXECUTIONS=100
PROFESSIONAL_TIER_USERS=25
PROFESSIONAL_TIER_EXECUTIONS=1000
ENTERPRISE_TIER_USERS=1000
ENTERPRISE_TIER_EXECUTIONS=100000

# ==============================================================================
# 🛡️  COMPLIANCE & AUDIT
# ==============================================================================

# Audit Configuration
AUDIT_ENABLED=true
AUDIT_RETENTION_DAYS=2555  # 7 years for compliance
AUDIT_LOG_ALL_REQUESTS=false
AUDIT_LOG_DATA_CHANGES=true

# Compliance Features
GDPR_COMPLIANCE=true
SOC2_COMPLIANCE=true
HIPAA_COMPLIANCE=false

# Data Retention
USER_DATA_RETENTION_DAYS=2555
EXECUTION_DATA_RETENTION_DAYS=365
LOG_DATA_RETENTION_DAYS=90

# ==============================================================================
# 🌍 LOCALIZATION
# ==============================================================================

# Internationalization
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,de,fr,es,zh
DEFAULT_TIMEZONE=UTC
ENABLE_RTL=false

# ==============================================================================
# 🔄 FEATURE FLAGS
# ==============================================================================

# Feature Toggles
ENABLE_NEW_DASHBOARD=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_MOBILE_APP_SUPPORT=true
ENABLE_API_V2=false
ENABLE_EXPERIMENTAL_TOOLS=false

# Beta Features
ENABLE_AI_RECOMMENDATIONS=true
ENABLE_AUTOMATED_REMEDIATION=false
ENABLE_THREAT_INTELLIGENCE=true

# ==============================================================================
# ⚡ TOOL EXECUTION CONFIGURATION
# ==============================================================================

# Execution Limits
MAX_CONCURRENT_EXECUTIONS=10
MAX_EXECUTION_TIME=1800000  # 30 minutes
MAX_OUTPUT_SIZE=50mb
EXECUTION_CLEANUP_INTERVAL=300000

# Tool Categories
ENABLED_TOOL_CATEGORIES=network_scanning,vulnerability_assessment,penetration_testing,forensics,mobile_security,web_application,database_security,cloud_security

# Queue Configuration
EXECUTION_QUEUE_ENABLED=true
EXECUTION_QUEUE_CONCURRENCY=5
EXECUTION_QUEUE_RETRY_ATTEMPTS=3

# ==============================================================================
# 📈 ANALYTICS & REPORTING
# ==============================================================================

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=365
ENABLE_USAGE_STATISTICS=true
ENABLE_PERFORMANCE_METRICS=true

# Reporting Configuration
REPORT_GENERATION_ENABLED=true
REPORT_MAX_SIZE=100mb
REPORT_CLEANUP_DAYS=30
SUPPORTED_REPORT_FORMATS=pdf,json,csv,xml

# ==============================================================================
# 🔌 THIRD-PARTY INTEGRATIONS
# ==============================================================================

# Vulnerability Databases
NVD_API_KEY=
CVE_DATABASE_UPDATE_INTERVAL=86400000

# Threat Intelligence
MISP_URL=
MISP_API_KEY=
THREAT_INTEL_ENABLED=false

# SIEM Integration
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=
ELASTICSEARCH_URL=

# ==============================================================================
# 🎯 DEVELOPMENT & TESTING
# ==============================================================================

# Testing Configuration (Production: disabled)
ENABLE_TEST_ENDPOINTS=false
MOCK_EXTERNAL_SERVICES=false
TEST_DATA_SEEDING=false

# Development Tools (Production: disabled)
ENABLE_DEBUG_TOOLBAR=false
ENABLE_PROFILING=false
HOT_RELOAD=false

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================

# Note: This configuration is optimized for production deployment
# Sensitive values should be managed through secure secret management systems
# Never commit actual secrets to version control